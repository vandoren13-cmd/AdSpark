rules_version = '2';

// Generated images are uploaded server-side via the Admin SDK and served through
// tokenized Firebase download URLs (which bypass these rules). The client never
// reads or writes Storage directly. Deny all direct client access.
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
