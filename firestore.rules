rules_version = '2';

// AdSpark data is accessed ONLY server-side through the Firebase Admin SDK
// (Next.js API routes), which bypasses these rules entirely. The client app uses
// Firebase for Authentication only — it never reads or writes Firestore directly.
// Therefore: deny all direct client access. This is the secure default.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
