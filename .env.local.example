# ── AdSpark AI — environment ──
# Copy to .env.local and fill in. NEVER commit .env.local.

# Firebase WEB config (client) — reuse the VanDoren-EMPIRE project (ai-empire-a9da3)
# or a new Firebase project. From Firebase console → Project settings → Your apps.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase ADMIN (server — verifies user tokens + writes quotas). From a service
# account JSON (Project settings → Service accounts → Generate new private key).
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# AI providers — ad COPY = Claude (best quality), ad IMAGES = OpenAI gpt-image-1.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Image model-router (optional) — which engine generates images. Defaults to
# openai-gpt-image-1. gpt-image-1 deprecates 2026-10-23; add engines in lib/ai.ts.
IMAGE_ENGINE=

# Stripe (Phase 3 — leave blank until you wire payments)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Price IDs for each tier (create them in the Stripe dashboard)
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_AGENCY=

# The app's public URL (for Stripe redirects). Local: http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Operator access to /admin — comma-separated emails (must match your AdSpark login email)
ADMIN_EMAILS=

# Transactional email (optional) — Resend HTTP API. Until set, emails no-op (logged).
# Verify a sending domain in Resend and set EMAIL_FROM to an address on it.
RESEND_API_KEY=
EMAIL_FROM=AdSpark AI <noreply@yourdomain.com>
EMAIL_REPLY_TO=

# Meta Marketing API (optional) — done-for-you campaign deployment + results sync.
# Until set, campaigns save as drafts and results can be entered manually.
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
META_API_VERSION=v21.0

# Google Ads API (optional) — campaign deployment + insights for Google.
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_API_VERSION=v23

# TikTok Marketing API (optional) — campaign deployment + insights for TikTok.
TIKTOK_ACCESS_TOKEN=
TIKTOK_ADVERTISER_ID=
TIKTOK_API_VERSION=v1.3
